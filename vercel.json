{
  "rewrites": [
    { "source": "/", "destination": "/claudeindex.html" },
    { "source": "/index", "destination": "/claudeindex.html" },
    { "source": "/intake", "destination": "/intake.html" },
    { "source": "/report", "destination": "/report.html" },
    { "source": "/modules", "destination": "/modules.html" },
    { "source": "/ipo", "destination": "/ipo.html" }
  ],
  "headers": [
    {
      "source": "/(.*)\\.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/(.*)\\.css",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)\\.svg",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
